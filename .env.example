# URL base del API (Turnerito). En prod apunta a la VM en Coolify.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Interruptor de mocks. "enabled" => MSW intercepta. Cualquier otro valor => API real.
NEXT_PUBLIC_API_MOCKING=disabled

# URL del servidor de WebSocket (sala de espera en vivo). Es el backend. Por defecto = API_URL.
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Nota: el contrato ya trae el prefijo /v1 en cada path versionado, así que la baseURL
# (NEXT_PUBLIC_API_URL) es la raíz del backend, SIN /v1.
